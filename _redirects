# Cloudflare Pages/Workers redirects/rewrites.
# Keep /invite/<token> on the landing page (200 = rewrite, URL preserved) so the
# page's JS can read the token from the path and open the app. Target "/" (not
# /index.html) to avoid Cloudflare's clean-URL loop detection.
/invite/*    /     200

# /privacy serves privacy.html automatically via Cloudflare clean URLs, so no
# rule is needed.
